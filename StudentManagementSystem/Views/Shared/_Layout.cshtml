<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Dashboard - Student Management</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            display: flex;
            background: #0f172a;
            color: white;
        }

        .sidebar {
            width: 250px;
            height: 100vh;
            background: #1e293b;
            padding: 20px;
            position: fixed;
        }

            .sidebar h3 {
                color: #38bdf8;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: block;
                color: #cbd5f5;
                padding: 10px;
                text-decoration: none;
                border-radius: 8px;
            }

                .sidebar a:hover {
                    background: #334155;
                    color: white;
                }

        .main {
            margin-left: 250px;
            padding: 30px;
            width: 100%;
        }

        .card {
            border-radius: 15px;
            background: #1e293b;
            color: white;
        }

        .btn-custom {
            border-radius: 10px;
        }
    </style>
</head>

<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <h3>🎓 Dashboard</h3>

        <a href="/Student/Index">📊 Students</a>
        <a href="/Student/Create">➕ Add Student</a>
    </div>

    <!-- Main Content -->
    <div class="main">
        @RenderBody()
    </div>

</body>
</html>