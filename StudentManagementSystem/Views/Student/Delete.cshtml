@model StudentManagementSystem.Models.Student

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5 text-center">
    <h2 class="text-danger">Delete Student</h2>

    <p>Are you sure you want to delete <strong>@Model.Name</strong>?</p>

    <form method="post" asp-action="DeleteConfirmed">
        <input type="hidden" asp-for="Id" />

        <button class="btn btn-danger">Delete</button>
        <a class="btn btn-secondary" href="/Student/Index">Cancel</a>
    </form>
</div>