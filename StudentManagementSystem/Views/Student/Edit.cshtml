@model StudentManagementSystem.Models.Student

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">
    <h2>Edit Student</h2>

    <form method="post">
        <input type="hidden" asp-for="Id" />

        <input class="form-control mb-3" asp-for="Name" />
        <input class="form-control mb-3" asp-for="Email" />
        <input class="form-control mb-3" asp-for="Course" />

        <button class="btn btn-warning">Update</button>
        <a class="btn btn-secondary" href="/Student/Index">Back</a>
    </form>
</div>