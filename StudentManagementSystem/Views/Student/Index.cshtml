@model IEnumerable<StudentManagementSystem.Models.Student>

<h2 class="mb-4">📊 Student Dashboard</h2>

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card p-3">
            <h5>Total Students</h5>
            <h2>@Model.Count()</h2>
        </div>
    </div>
</div>

<a class="btn btn-success btn-custom mb-3" href="/Student/Create">+ Add Student</a>

<form method="get" class="mb-3">
    <input type="text" name="search" class="form-control" placeholder="Search by Name, Email or Course..." />
</form>

<table class="table table-dark table-hover rounded">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Course</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Course</td>
                <td>
                    <a class="btn btn-warning btn-sm" href="/Student/Edit/@item.Id">Edit</a>
                    <a class="btn btn-danger btn-sm" href="/Student/Delete/@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a class="btn btn-primary mb-3" href="/Student/ExportToExcel">Export Excel</a>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>