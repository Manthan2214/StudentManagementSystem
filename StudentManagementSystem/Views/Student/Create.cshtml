@model StudentManagementSystem.Models.Student

<h2 class="mb-4">➕ Add Student</h2>

<div class="card p-4 col-md-6">
    <form method="post">

        <input class="form-control mb-3" asp-for="Name" placeholder="Enter Name" />
        <input class="form-control mb-3" asp-for="Email" placeholder="Enter Email" />
        <input class="form-control mb-3" asp-for="Course" placeholder="Enter Course" />

        <button class="btn btn-success btn-custom">Save</button>
        <a class="btn btn-secondary btn-custom" href="/Student/Index">Back</a>

    </form>
</div>